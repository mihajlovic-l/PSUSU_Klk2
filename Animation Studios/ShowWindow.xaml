<Window x:Class="Animation_Studios.ShowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Show" Height="450" Width="500">
    <ScrollViewer>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Name" />
        <TextBox x:Name="NameBox" Grid.Row="0" Margin="120,0,0,0" Width="300" />

        <TextBlock Text="Started" Grid.Row="1" />
        <DatePicker x:Name="StartedPicker" Grid.Row="1" Margin="120,0,0,0" />

        <TextBlock Text="Ended" Grid.Row="2" />
        <DatePicker x:Name="EndedPicker" Grid.Row="2" Margin="120,0,0,0" />

        <TextBlock Text="Director" Grid.Row="3" />
        <TextBox x:Name="DirectorBox" Grid.Row="3" Margin="120,0,0,0" Width="300" />

        <TextBlock Text="Number of episodes" Grid.Row="4" />
        <TextBox x:Name="EpisodesBox" Grid.Row="4" Margin="160,0,0,0" Width="80" />

        <TextBlock Text="Genre" Grid.Row="5" />
        <StackPanel Grid.Row="5" Margin="120,0,0,0" Orientation="Horizontal">
            <ListBox x:Name="GenreList" SelectionMode="Multiple" Width="300">
                <!-- Items added in code-behind -->
            </ListBox>
        </StackPanel>

        <TextBlock Text="Rating" Grid.Row="6" />
        <StackPanel Grid.Row="6" Margin="120,0,0,0" Orientation="Horizontal">
            <StackPanel x:Name="RatingPanel" Orientation="Horizontal" />
        </StackPanel>

        <TextBlock Text="Status" Grid.Row="7" />
        <ComboBox x:Name="StatusCombo" Grid.Row="7" Margin="120,0,0,0" Width="150" />

        <CheckBox x:Name="MovieCheck" Content="Movie" Grid.Row="7" HorizontalAlignment="Right" Margin="0,0,120,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="8" Margin="0,10,0,0">
            <Button x:Name="OkButton" Width="75" Margin="0,0,10,0">OK</Button>
            <Button Width="75" Click="Cancel_Click">Cancel</Button>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
